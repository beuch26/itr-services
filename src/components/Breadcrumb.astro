---
import { services } from "../data/services";

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items?: BreadcrumbItem[];
}

const { items = [{ label: "Accueil", href: "/" }] } = Astro.props;
---

<nav class="bg-white border-b border-gray-100" aria-label="Fil d'ariane">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center justify-between">
      <!-- Breadcrumb -->
      <ol class="flex items-center gap-1.5 text-sm text-gray-500" itemscope itemtype="https://schema.org/BreadcrumbList">
        {items.map((item, i) => (
          <li class="flex items-center gap-1.5" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            {i > 0 && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            )}
            {i === items.length - 1 ? (
              <span class="text-dark-blue font-medium" itemprop="name">{item.label}</span>
            ) : (
              <a href={item.href} class="hover:text-primary transition-colors no-underline" itemprop="item">
                <span itemprop="name">{item.label}</span>
              </a>
            )}
            <meta itemprop="position" content={String(i + 1)} />
          </li>
        ))}
      </ol>

      <!-- Services dropdown (mobile compact) -->
      <div class="relative" id="services-dropdown">
        <button
          id="services-dropdown-btn"
          class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-primary transition-colors px-3 py-1.5 rounded-lg hover:bg-gray-50"
          aria-expanded="false"
        >
          <span class="hidden sm:inline">Nos services</span>
          <span class="sm:hidden">Services</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div id="services-dropdown-menu" class="hidden absolute right-0 top-full mt-1 bg-white rounded-xl shadow-lg border border-gray-100 py-2 w-72 z-30">
          {services.map((service) => (
            <a
              href={`/${service.slug}`}
              class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary transition-colors no-underline"
            >
              <span>{service.name}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("services-dropdown-btn");
  const menu = document.getElementById("services-dropdown-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (!document.getElementById("services-dropdown")?.contains(e.target as Node)) {
      menu?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    }
  });
</script>
