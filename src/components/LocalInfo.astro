---
import { siteConfig } from "../data/siteConfig";
import CTAButton from "./CTAButton.astro";

interface Props {
  mapCenter?: [number, number];
  mapZoom?: number;
  mapRadius?: number;
  mapPopupText?: string;
  areasDetailed?: string[];
  localInfoTitle?: string;
  localInfoText?: string;
}

const {
  mapCenter = [50.845, 4.350],
  mapZoom = 11,
  mapRadius = 8000,
  mapPopupText = "<strong>Zone d'intervention ITR Services</strong><br>Bruxelles et toutes les communes",
  areasDetailed = siteConfig.areasDetailed,
  localInfoTitle = "Plombier à Bruxelles – Dépannage 24h/24",
  localInfoText = `Une fuite d'eau, une canalisation bouchée ou un problème de plomberie ? Notre plombier intervient <strong class="text-dark-blue">rapidement</strong> dans toutes les communes de Bruxelles, 24h/24 et 7j/7. Profitez d'un service professionnel, rapide et au prix juste.`,
} = Astro.props;
---

<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Map -->
      <div
        class="animate-on-scroll rounded-2xl overflow-hidden shadow-lg h-[300px] md:h-[400px] relative bg-surface"
        id="map-container"
        data-center={JSON.stringify(mapCenter)}
        data-zoom={mapZoom}
        data-radius={mapRadius}
        data-popup={mapPopupText}
      >
        <div id="intervention-map" class="w-full h-full z-0"></div>
      </div>

      <!-- Text -->
      <div class="animate-on-scroll delay-1">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-blue mb-5">
          {localInfoTitle}
        </h2>
        <p class="text-gray-600 text-lg leading-relaxed mb-6" set:html={localInfoText} />

        {areasDetailed.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {areasDetailed.map((area) => (
              <span class="inline-flex items-center gap-1.5 bg-surface rounded-xl px-3.5 py-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="font-heading font-semibold text-dark-blue">{area}</span>
              </span>
            ))}
          </div>
        )}

        <div class="flex flex-wrap gap-6 text-sm text-gray-600 mb-8">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Intervention <strong>rapide</strong></span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span><strong>Disponible 24h/24</strong>, 7j/7</span>
          </div>
        </div>

        <div class="flex justify-center lg:justify-start">
          <CTAButton
            text="Appelez votre plombier local"
            subtext="Intervention rapide dans votre quartier"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Lazy-load Leaflet only when map container is visible
  (function() {
    var mapLoaded = false;
    var container = document.getElementById('map-container');
    if (!container) return;

    var center = JSON.parse(container.dataset.center || '[50.845,4.350]');
    var zoom = parseInt(container.dataset.zoom || '11');
    var radius = parseInt(container.dataset.radius || '8000');
    var popupText = container.dataset.popup || "Zone d'intervention ITR Services";

    function loadMap() {
      if (mapLoaded) return;
      mapLoaded = true;

      // Load Leaflet CSS
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(link);

      // Load Leaflet JS
      var script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.onload = initMap;
      document.head.appendChild(script);
    }

    function initMap() {
      var map = L.map('intervention-map', {
        scrollWheelZoom: false,
        dragging: true,
        zoomControl: true,
      }).setView(center, zoom);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
        maxZoom: 19,
      }).addTo(map);

      var zoneStyle = {
        color: '#FF6B35',
        weight: 2,
        opacity: 0.6,
        fillColor: '#FF6B35',
        fillOpacity: 0.12,
      };

      L.circle(center, {
        radius: radius,
        ...zoneStyle,
      }).addTo(map).bindPopup(popupText);

      var icon = L.divIcon({
        html: '<div style="background:#0A2540;color:white;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.3);border:2px solid white;">ITR</div>',
        className: '',
        iconSize: [36, 36],
        iconAnchor: [18, 18],
      });

      L.marker(center, { icon: icon }).addTo(map)
        .bindPopup('<strong>ITR Services</strong><br>Votre plombier local<br><a href="tel:+32470960823">+32 470 96 08 23</a>');
    }

    // Use IntersectionObserver to lazy-load
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          loadMap();
          observer.disconnect();
        }
      }, { rootMargin: '200px' });
      observer.observe(container);
    } else {
      // Fallback for old browsers
      loadMap();
    }
  })();
</script>
