---
import CTAButton from "./CTAButton.astro";
import ImagePrompt from "./ImagePrompt.astro";

interface Props {
  title: string;
  text: string;
  imagePrompt: string;
  imageAlt: string;
  imageSrc?: string;
  imagePosition?: "left" | "right";
  ctaText?: string;
  ctaSubtext?: string;
  features?: string[];
}

const {
  title,
  text,
  imagePrompt,
  imageAlt,
  imageSrc,
  imagePosition = "right",
  ctaText = "Appelez maintenant",
  ctaSubtext = "Intervention rapide - Devis gratuit",
  features = [],
} = Astro.props;
---

<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class:list={[
      "grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center",
      imagePosition === "left" && "lg:[direction:rtl]"
    ]}>
      <!-- Text -->
      <div class="animate-on-scroll lg:[direction:ltr]">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-blue mb-5 leading-tight">
          {title}
        </h2>
        <p class="text-gray-600 text-lg leading-relaxed mb-6">
          {text}
        </p>

        {features.length > 0 && (
          <ul class="space-y-3 mb-8">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        )}

        <div class="flex justify-center lg:justify-start">
          <CTAButton text={ctaText} subtext={ctaSubtext} />
        </div>
      </div>

      <!-- Image -->
      <div class="animate-on-scroll delay-1 lg:[direction:ltr]">
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <ImagePrompt
            prompt={imagePrompt}
            alt={imageAlt}
            src={imageSrc}
            class="w-full h-[300px] md:h-[400px] object-cover"
            width={600}
            height={400}
          />
        </div>
      </div>
    </div>
  </div>
</section>
