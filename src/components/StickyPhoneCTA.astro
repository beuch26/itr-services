---
import { siteConfig } from "../data/siteConfig";
---

<!-- Scroll sentinel -->
<div id="scroll-sentinel" class="absolute top-[350px] h-px w-px pointer-events-none" aria-hidden="true"></div>

<!-- Sticky phone CTA bar -->
<div
  id="sticky-cta"
  class="fixed bottom-0 inset-x-0 z-40 translate-y-full transition-transform duration-500 cubic-bezier(0.22, 1, 0.36, 1)"
>
  <!-- Top glow -->
  <div class="h-px bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>

  <a
    href={siteConfig.phoneTel}
    class="relative flex items-center justify-center gap-3 bg-gradient-to-r from-accent via-accent-hover to-accent text-white py-4 px-4 no-underline transition-colors overflow-hidden group"
  >
    <!-- Shimmer overlay -->
    <div class="absolute inset-0 shimmer pointer-events-none"></div>

    <div class="relative z-10 flex items-center gap-3">
      <!-- Ringing phone icon -->
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 animate-ring" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <!-- Pulse ring -->
        <span class="absolute -inset-1 rounded-full border-2 border-white/30 animate-ping"></span>
      </div>

      <div class="flex flex-col">
        <span class="font-heading font-bold text-base sm:text-lg leading-tight tracking-tight">
          Appel Gratuit : {siteConfig.phone}
        </span>
        <span class="text-[11px] text-white/90 tracking-wide">
          Intervention rapide 24h/24 &bull; Devis gratuit &bull; Sans engagement
        </span>
      </div>
    </div>
  </a>
</div>

<script>
  const sentinel = document.getElementById("scroll-sentinel");
  const cta = document.getElementById("sticky-cta");

  if (sentinel && cta) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          cta.classList.add("translate-y-full");
          cta.classList.remove("translate-y-0");
        } else {
          cta.classList.remove("translate-y-full");
          cta.classList.add("translate-y-0");
        }
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);
  }
</script>
