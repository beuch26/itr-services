---
const brands = [
  { name: "Grohe", logo: "/images/partenaires/grohe.webp" },
  { name: "Hansgrohe", logo: "/images/partenaires/hansgrohe.webp" },
  { name: "Geberit", logo: "/images/partenaires/geberit.webp" },
  { name: "Villeroy & Boch", logo: "/images/partenaires/villeroy-boch.webp" },
  { name: "Porcher", logo: "/images/partenaires/porcher.webp" },
  { name: "Hüppe", logo: "/images/partenaires/huppe.webp" },
  { name: "Franke", logo: "/images/partenaires/franke.webp" },
  { name: "Merlin Gerin", logo: "/images/partenaires/merlin-gerin.webp" },
  { name: "Philips", logo: "/images/partenaires/philips.webp" },
];
---

<section class="bg-surface py-10 md:py-14 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <p class="text-sm font-heading font-semibold text-gray-500 uppercase tracking-wider">
        Nos marques partenaires
      </p>
    </div>
  </div>

  <!-- Marquee with fade edges -->
  <div class="relative">
    <!-- Fade left -->
    <div class="absolute left-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-r from-surface to-transparent z-10 pointer-events-none"></div>
    <!-- Fade right -->
    <div class="absolute right-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-l from-surface to-transparent z-10 pointer-events-none"></div>

    <div class="brands-marquee flex items-center gap-14 md:gap-20">
      {/* Double the items for seamless loop */}
      {[...brands, ...brands].map((brand) => (
        <div class="flex-shrink-0 flex items-center justify-center px-2 opacity-40 hover:opacity-100 transition-all duration-300 grayscale hover:grayscale-0">
          <img
            src={brand.logo}
            alt={brand.name}
            class="h-10 md:h-12 lg:h-14 max-w-[120px] md:max-w-[140px] w-auto object-contain"
            loading="lazy"
            decoding="async"
            width={140}
            height={56}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .brands-marquee {
    animation: marquee 30s linear infinite;
    width: max-content;
  }

  .brands-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
