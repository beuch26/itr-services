---
import { siteConfig } from "../data/siteConfig";
import { services } from "../data/services";
---

<footer class="bg-dark-blue text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company -->
      <div>
        <div class="mb-4">
          <img
            src="/images/logo-itr-white.png"
            alt="ITR Services"
            class="h-12 w-auto"
          />
        </div>
        <p class="text-white/70 text-sm leading-relaxed mb-4">
          {siteConfig.slogan}. Votre plombier de confiance à {siteConfig.areasShort}.
        </p>
        <a href={siteConfig.phoneTel} class="flex items-center gap-2 text-accent hover:text-accent-hover font-bold transition-colors no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {siteConfig.phone}
        </a>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Nos services</h3>
        <ul class="space-y-2">
          {services.map((service) => (
            <li>
              <a href={`/${service.slug}`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Zones -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Zones d'intervention</h3>
        <div class="flex flex-wrap gap-1.5">
          {siteConfig.areasDetailed.map((area) => (
            <span class="inline-block text-white/70 text-xs bg-white/[0.06] rounded-lg px-2.5 py-1.5 hover:bg-white/[0.1] hover:text-white transition-colors">
              {area}
            </span>
          ))}
        </div>
      </div>

      <!-- Contact & Legal -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Contact</h3>
        <ul class="space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href={`mailto:${siteConfig.email}`} class="text-white/70 hover:text-white transition-colors no-underline">
              {siteConfig.email}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Disponible {siteConfig.availability}</span>
          </li>
        </ul>
        <div class="mt-6">
          <a href="/mentions-legales" class="text-white/50 hover:text-white text-sm transition-colors no-underline">
            Mentions légales
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/10 text-center text-white/50 text-sm">
      <p>&copy; {new Date().getFullYear()} {siteConfig.companyName}. Tous droits réservés.</p>
    </div>
  </div>
</footer>
