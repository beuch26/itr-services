---
const photos = [
  {
    src: "/images/portfolio/renovation-sdb-baignoire-ilot.webp",
    alt: "Avant/après rénovation salle de bain luxe avec baignoire îlot par ITR Services",
    label: "Rénovation salle de bain",
    type: "avant-apres" as const,
  },
  {
    src: "/images/portfolio/detection-camera-thermique.webp",
    alt: "Technicien ITR Services utilisant une caméra thermique pour détecter une fuite",
    label: "Détection fuite caméra thermique",
    type: "equipement" as const,
  },
  {
    src: "/images/portfolio/renovation-wc-geberit.webp",
    alt: "Avant/après installation WC suspendu Geberit par ITR Services",
    label: "Installation WC suspendu Geberit",
    type: "avant-apres" as const,
  },
  {
    src: "/images/portfolio/debouchage-chambre-visite.webp",
    alt: "Technicien ITR Services débouchant une chambre de visite avec hydrocurage",
    label: "Débouchage chambre de visite",
    type: "equipement" as const,
  },
  {
    src: "/images/portfolio/renovation-sdb-marbre-blanc.webp",
    alt: "Avant/après rénovation complète salle de bain en marbre blanc par ITR Services",
    label: "Rénovation complète salle de bain",
    type: "avant-apres" as const,
  },
  {
    src: "/images/portfolio/detection-ultrasons.webp",
    alt: "Technicien ITR Services détectant une fuite par ultra-sons",
    label: "Détection fuite par ultra-sons",
    type: "equipement" as const,
  },
  {
    src: "/images/portfolio/renovation-sdb-douche-moderne.webp",
    alt: "Avant/après rénovation salle de bain avec douche moderne et boiler par ITR Services",
    label: "Rénovation salle de bain & boiler",
    type: "avant-apres" as const,
  },
  {
    src: "/images/portfolio/debouchage-wc.webp",
    alt: "Technicien ITR Services débouchant un WC avec matériel professionnel",
    label: "Débouchage WC",
    type: "equipement" as const,
  },
  {
    src: "/images/portfolio/renovation-wc-marbre.webp",
    alt: "Avant/après rénovation WC avec carrelage marbre par ITR Services",
    label: "Rénovation WC complète",
    type: "avant-apres" as const,
  },
];
---

<section class="py-12 md:py-16 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <span class="text-xs font-heading font-bold uppercase tracking-[0.2em] text-primary mb-2 block">
        Portfolio
      </span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-blue mb-3">
        Nos réalisations en images
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Découvrez nos interventions avant/après et notre équipement professionnel de détection de fuites.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {photos.map((photo, i) => (
        <div class:list={[
          "group relative rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-on-scroll",
          `delay-${Math.min(i + 1, 3)}`
        ]}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-64 md:h-72 object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            decoding="async"
            width={400}
            height={288}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark-blue/80 via-dark-blue/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <span class:list={[
              "inline-block text-[10px] font-heading font-bold uppercase tracking-wider px-2.5 py-1 rounded-full mb-1.5",
              photo.type === "avant-apres" ? "bg-accent/90 text-white" : "bg-primary/90 text-white"
            ]}>
              {photo.type === "avant-apres" ? "Avant / Après" : "Équipement pro"}
            </span>
            <p class="text-white font-heading font-semibold text-sm drop-shadow-md">
              {photo.label}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
