---
import { reviews, type Review } from "../data/reviews";

interface Props {
  items?: Review[];
}

const { items = reviews } = Astro.props;

const initials = (name: string) => name.charAt(0);
const colors = ["from-primary to-primary-dark", "from-accent to-accent-hover", "from-dark-blue to-dark-blue-light"];
---

<section class="bg-surface py-12 md:py-16 relative overflow-hidden">
  <!-- Decorative -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -bottom-32 -left-32 w-64 h-64 bg-gold/[0.03] rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <span class="inline-flex items-center gap-2 text-xs font-heading font-bold uppercase tracking-[0.2em] text-gold mb-3">
        <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Avis clients Google
      </span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-blue mb-3 tracking-tight">
        Ce que disent nos clients
      </h2>
      <p class="text-gray-500 max-w-lg mx-auto mb-6">
        Nos clients à Bruxelles nous font confiance. Découvrez leurs témoignages.
      </p>

      <!-- Aggregate Google Rating -->
      <div class="inline-flex items-center gap-3 bg-white rounded-2xl px-6 py-3 shadow-sm ring-1 ring-gray-100">
        <svg class="w-6 h-6" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="flex items-center gap-2">
          <span class="text-2xl font-heading font-extrabold text-dark-blue">4.4</span>
          <div class="flex items-center gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class:list={["w-5 h-5", i < 4 ? "text-gold fill-gold" : "text-gray-200 fill-gray-200"]}
                viewBox="0 0 24 24"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>
        </div>
        <span class="text-sm text-gray-400">16 avis vérifiés</span>
      </div>
    </div>
  </div>

  <!-- Marquee reviews -->
  <div class="relative">
    <!-- Fade left -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-surface to-transparent z-10 pointer-events-none"></div>
    <!-- Fade right -->
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-surface to-transparent z-10 pointer-events-none"></div>

    <div class="reviews-marquee flex items-stretch gap-5">
      {[...items, ...items].map((review, i) => (
        <div class="flex-shrink-0 w-[320px] md:w-[360px] relative bg-white rounded-3xl p-7 ring-1 ring-gray-100">
          {/* Decorative quote mark */}
          <div class="absolute top-6 right-6 text-5xl font-heading font-extrabold text-gray-100 leading-none select-none">"</div>

          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-4 relative">
            {Array.from({ length: review.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold fill-gold" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="relative text-gray-600 leading-relaxed mb-6 text-[15px]">
            {review.text}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-gray-50">
            <div class:list={[
              "w-10 h-10 rounded-xl bg-gradient-to-br flex items-center justify-center shadow-sm",
              colors[i % colors.length]
            ]}>
              <span class="text-white font-heading font-bold text-sm">
                {initials(review.name)}
              </span>
            </div>
            <div>
              <p class="font-heading font-bold text-dark-blue text-sm tracking-tight">{review.name}</p>
              <p class="text-xs text-gray-400">{review.service} — {review.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews-marquee {
    animation: reviews-scroll 40s linear infinite;
    width: max-content;
  }

  .reviews-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes reviews-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
