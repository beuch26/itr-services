---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="bg-surface py-10 md:py-14">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark-blue mb-6">
      {title}
    </h2>
    <div class="prose prose-gray max-w-none text-gray-600 leading-relaxed space-y-4">
      <slot />
    </div>
  </div>
</section>
