---
import { siteConfig } from "../data/siteConfig";

interface Props {
  text?: string;
  subtext?: string;
  href?: string;
  variant?: "accent" | "primary" | "white";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  text = "Appelez maintenant",
  subtext = "Intervention rapide - Devis gratuit",
  href = siteConfig.phoneTel,
  variant = "accent",
  size = "md",
  class: className = "",
} = Astro.props;

const variantClasses = {
  accent: "bg-gradient-to-r from-accent to-accent-hover text-white shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30",
  primary: "bg-gradient-to-r from-primary to-primary-dark text-white shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30",
  white: "bg-white hover:bg-gray-50 text-dark-blue shadow-lg shadow-black/5 hover:shadow-xl hover:shadow-black/10 ring-1 ring-gray-100",
};

const sizeClasses = {
  sm: "px-5 py-2.5 text-sm",
  md: "px-7 py-3.5 text-base",
  lg: "px-10 py-5 text-lg",
};
---

<a
  href={href}
  class:list={[
    "inline-flex flex-col items-center justify-center rounded-2xl font-heading font-bold transition-all duration-300 hover:-translate-y-1 no-underline relative overflow-hidden group",
    variantClasses[variant],
    sizeClasses[size],
    className,
  ]}
>
  {variant !== "white" && <div class="absolute inset-0 shimmer pointer-events-none"></div>}
  <span class="relative z-10 flex items-center gap-2">
    {href?.startsWith("tel:") && (
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:animate-ring" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
    )}
    {!href?.startsWith("tel:") && (
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    )}
    {text}
  </span>
  {subtext && (
    <span class="relative z-10 text-[11px] font-body font-normal opacity-85 mt-0.5 tracking-wide">{subtext}</span>
  )}
</a>
