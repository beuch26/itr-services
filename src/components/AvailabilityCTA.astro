---
import { siteConfig } from "../data/siteConfig";
---

<div class="w-full max-w-xl mx-auto animate-on-scroll">
  <div class="relative bg-gradient-to-r from-primary/5 via-primary/10 to-primary/5 rounded-3xl p-6 md:p-8">
    <!-- Form -->
    <form id="availability-form" class="flex flex-col sm:flex-row items-stretch gap-3">
      <div class="flex-1 relative">
        <input
          type="text"
          id="avail-codepostal"
          placeholder="Saisissez votre code postal (ex: 1000)"
          class="w-full px-5 py-4 rounded-2xl border-0 bg-white shadow-sm ring-1 ring-gray-200 focus:ring-2 focus:ring-primary outline-none transition-all text-sm text-gray-700 placeholder-gray-400"
        />
      </div>
      <a
        href={siteConfig.phoneTel}
        id="avail-submit"
        class="inline-flex items-center justify-center gap-2 bg-dark-blue hover:bg-dark-blue-light text-white font-heading font-bold px-7 py-4 rounded-2xl transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg no-underline whitespace-nowrap cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Obtenir disponibilités
      </a>
    </form>

    <!-- Mini texts -->
    <div class="flex flex-wrap items-center justify-center gap-4 mt-4">
      <span class="inline-flex items-center gap-1.5 text-xs text-gray-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        RDV en 5 min
      </span>
      <span class="inline-flex items-center gap-1.5 text-xs text-gray-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        Diagnostic & Conseil gratuit
      </span>
      <span class="inline-flex items-center gap-1.5 text-xs text-gray-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Sans engagement
      </span>
    </div>
  </div>
</div>
