---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { blogArticles } from "../../data/blog";
import { siteConfig } from "../../data/siteConfig";

export function getStaticPaths() {
  return blogArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString("fr-BE", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const categoryColors: Record<string, string> = {
  "Plomberie depannage": "bg-primary/10 text-primary",
  "Fuite d'eau": "bg-blue-50 text-blue-700",
  "Debouchage": "bg-amber-50 text-amber-700",
  "Boiler": "bg-orange-50 text-orange-700",
  "Renovation salle de bain": "bg-emerald-50 text-emerald-700",
};

// Get related articles from same category (excluding current)
const relatedArticles = blogArticles
  .filter((a) => a.categorySlug === article.categorySlug && a.slug !== article.slug)
  .slice(0, 2);
---

<BaseLayout
  title={`${article.title} | Blog ITR Services`}
  description={article.excerpt}
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: article.title, href: `/blog/${article.slug}` },
  ]} />

  <article class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Article Header -->
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-semibold px-3 py-1 rounded-full ${categoryColors[article.category] || "bg-gray-100 text-gray-600"}`}>
            {article.category}
          </span>
          <time class="text-sm text-gray-400" datetime={article.date}>
            {formatDate(article.date)}
          </time>
        </div>
        <h1 class="font-heading text-3xl sm:text-4xl font-bold text-dark-blue leading-tight">
          {article.title}
        </h1>
        <p class="mt-4 text-lg text-gray-600 leading-relaxed">
          {article.excerpt}
        </p>
      </header>

      <!-- Article Content -->
      <div class="prose prose-lg max-w-none" set:html={article.content} />

      <!-- Author / Company Box -->
      <div class="mt-12 p-6 bg-surface rounded-2xl border border-gray-100">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-bold text-dark-blue">{siteConfig.companyName}</p>
            <p class="text-sm text-gray-500">Plombiers professionnels en Belgique - Disponible {siteConfig.availability}</p>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="bg-surface py-12 sm:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-2xl font-bold text-dark-blue mb-8 text-center">
          Articles similaires
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          {relatedArticles.map((related) => (
            <a
              href={`/blog/${related.slug}`}
              class="group bg-white rounded-2xl border border-gray-100 p-6 shadow-sm hover:shadow-lg hover:border-primary/20 transition-all duration-300 no-underline"
            >
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${categoryColors[related.category] || "bg-gray-100 text-gray-600"}`}>
                {related.category}
              </span>
              <h3 class="font-heading text-lg font-bold text-dark-blue mt-3 mb-2 group-hover:text-primary transition-colors leading-snug">
                {related.title}
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                {related.excerpt}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="bg-dark-blue py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-4">
        Besoin d'un plombier professionnel ?
      </h2>
      <p class="text-white/70 text-lg mb-8">
        Intervention rapide dans toute la Belgique. Devis gratuit et transparent, sans engagement.
      </p>
      <a
        href={siteConfig.phoneTel}
        class="inline-flex items-center gap-3 bg-accent hover:bg-accent-hover text-white font-bold text-lg px-8 py-4 rounded-xl shadow-lg shadow-accent/30 hover:shadow-xl hover:shadow-accent/40 transition-all duration-300 no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Appelez-nous : {siteConfig.phone}
      </a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-dark-blue);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .prose h3 {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-dark-blue);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: #475569;
  }
  .prose ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    color: #475569;
  }
  .prose li::marker {
    color: var(--color-primary);
  }
  .prose a {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .prose a:hover {
    color: var(--color-primary-dark);
  }
  .prose strong {
    color: var(--color-dark-blue);
    font-weight: 600;
  }
</style>
