---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { blogArticles } from "../../data/blog";
import { siteConfig } from "../../data/siteConfig";

const sortedArticles = [...blogArticles].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const categoryColors: Record<string, string> = {
  "Plomberie depannage": "bg-primary/10 text-primary",
  "Fuite d'eau": "bg-blue-50 text-blue-700",
  "Debouchage": "bg-amber-50 text-amber-700",
  "Boiler": "bg-orange-50 text-orange-700",
  "Renovation salle de bain": "bg-emerald-50 text-emerald-700",
};

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString("fr-BE", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<BaseLayout
  title="Blog Plomberie | Conseils et astuces - ITR Services"
  description="Retrouvez nos articles et conseils en plomberie : urgences, fuites d'eau, debouchage, boiler, renovation salle de bain. Guides pratiques par des plombiers professionnels en Belgique."
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Blog", href: "/blog" },
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-surface to-white py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-dark-blue mb-4">
        Blog Plomberie
      </h1>
      <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
        Conseils pratiques, guides et astuces de nos plombiers professionnels pour entretenir votre installation et reagir en cas de probleme.
      </p>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedArticles.map((article, i) => (
          <article
            class={`animate-on-scroll ${i > 0 ? `delay-${Math.min(i % 3 + 1, 3)}` : ""} group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg hover:border-primary/20 transition-all duration-300 flex flex-col`}
          >
            <!-- Category & Date -->
            <div class="p-6 pb-0 flex items-center justify-between gap-3">
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${categoryColors[article.category] || "bg-gray-100 text-gray-600"}`}>
                {article.category}
              </span>
              <time class="text-xs text-gray-400" datetime={article.date}>
                {formatDate(article.date)}
              </time>
            </div>

            <!-- Content -->
            <div class="p-6 flex-1 flex flex-col">
              <h2 class="font-heading text-lg font-bold text-dark-blue mb-3 group-hover:text-primary transition-colors leading-snug">
                <a href={`/blog/${article.slug}`} class="no-underline text-inherit">
                  {article.title}
                </a>
              </h2>
              <p class="text-sm text-gray-600 leading-relaxed flex-1 mb-4">
                {article.excerpt}
              </p>
              <a
                href={`/blog/${article.slug}`}
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-dark transition-colors no-underline"
              >
                Lire l'article
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/>
                  <path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-dark-blue py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-4">
        Un probleme de plomberie ?
      </h2>
      <p class="text-white/70 text-lg mb-8">
        Nos plombiers professionnels interviennent rapidement dans toute la Belgique. Devis gratuit et transparent.
      </p>
      <a
        href={siteConfig.phoneTel}
        class="inline-flex items-center gap-3 bg-accent hover:bg-accent-hover text-white font-bold text-lg px-8 py-4 rounded-xl shadow-lg shadow-accent/30 hover:shadow-xl hover:shadow-accent/40 transition-all duration-300 no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {siteConfig.phone}
      </a>
    </div>
  </section>
</BaseLayout>
