---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import { siteConfig } from "../data/siteConfig";
import { getFaqFuite } from "../data/faq";
import { pricingFuite } from "../data/pricing";
import { getZone } from "../data/zones";
import LiveBadge from "../components/LiveBadge.astro";
import AvailabilityCTA from "../components/AvailabilityCTA.astro";
import CallbackModal from "../components/CallbackModal.astro";

const zone = getZone("namur");
const faqItems = getFaqFuite(zone.citiesInline);
---

<BaseLayout
  title="Recherche & Réparation de Fuite Namur et Alentours | ITR Services"
  description={`Recherche et réparation de fuite d'eau à Namur et ses alentours. Détection non destructive par caméra thermique. Intervention 24h/24. Devis gratuit. Appelez le ${siteConfig.phone}.`}
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Recherche & Réparation de fuite", href: "/recherche-reparation-fuite-namur" },
  ]} />

  <HeroSection
    h1="Recherche & réparation de fuite à Namur et ses alentours"
    slogan="On trouve la fuite, on la répare. Sans casser vos murs."
    description="Détection par caméra thermique et réparation immédiate sur place. <strong class='text-gray-700'>Intervention 24h/24</strong>, devis gratuit."
    imagePrompt=""
    imageAlt="Détection de fuite par caméra thermique - ITR Services"
    imageSrc="/images/plombier-itr-services.webp"
  />

  <!-- Social proof: Full reviews -->
  <SocialProofFull />

  <!-- Local Info (zone d'intervention) -->
  <LocalInfo
    mapCenter={zone.mapCenter}
    mapZoom={zone.mapZoom}
    mapRadius={zone.mapRadius}
    mapPopupText={zone.mapPopupText}
    areasDetailed={zone.areasDetailed}
    localInfoTitle={`Recherche de fuite à ${zone.citiesInline} – Intervention 24h/24`}
    localInfoText={zone.localInfoText}
  />

  <!-- Service details -->
  <TextImageCTA
    title="On trouve votre fuite sans casser ni percer."
    text="Tache d'humidité au plafond, compteur d'eau qui s'emballe, mur qui gondole… Une fuite cachée peut faire des dégâts bien avant d'être visible. Nos plombiers utilisent la caméra thermique, le détecteur d'humidité et la caméra d'inspection pour localiser la fuite au millimètre près — sans toucher à vos murs ni à vos sols."
    imagePrompt=""
    imageAlt="Technicien ITR Services utilisant un détecteur à ultra-sons pour localiser une fuite"
    imageSrc="/images/portfolio/detection-ultrasons.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Détection précise - Devis gratuit"
    features={[
      "Détection par acoustique (ultra-sons)",
      "Détection par colorant",
      "Détection par humidimètre",
      "Détection par caméra thermique",
      "Détection par caméra endoscopique",
    ]}
  />

  <TextImageCTA
    title="Fuite trouvée, fuite réparée — dans la foulée."
    text="Pas besoin de revenir un autre jour. Une fois la source identifiée, nos plombiers réparent immédiatement : raccord, joint, canalisation, vanne — peu importe l'origine. On utilise des pièces solides et éprouvées pour que la réparation tienne dans le temps."
    imagePrompt=""
    imageAlt="Appareil de détection thermique professionnel"
    imageSrc="/images/portfolio/detection-colorant-toiture.webp"
    imagePosition="left"
    ctaText="Appeler Joseph"
    ctaSubtext="Réparation garantie - Sans engagement"
    features={[
      "Réparation sur place, le jour même",
      "Pièces et matériaux de marques reconnues",
      "Garantie sur chaque réparation",
      "Disponible en urgence 24h/24",
    ]}
  />

  <TextImageCTA
    title="Une fuite ignorée, c'est une facture qui explose."
    text="Une fuite cachée, même minime, peut causer bien plus de dégâts qu'on ne l'imagine. Infiltrations dans les murs, moisissures, dommages structurels, surconsommation d'eau — les conséquences s'accumulent jour après jour. Nos plombiers interviennent dans les heures qui suivent votre appel à Namur et ses alentours pour stopper les dégâts avant qu'ils ne deviennent irréversibles."
    imagePrompt=""
    imageAlt="Détection de fuite par caméra thermique professionnelle"
    imageSrc="/images/portfolio/detection-fuite-thermique.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Intervention urgente - Dès 249€"
    features={[
      "Évitez les dégâts structurels coûteux",
      "Stoppez la surconsommation d'eau immédiatement",
      "Prévenez les moisissures et problèmes de santé",
      "Rapport d'intervention pour votre assurance",
    ]}
  />

  <!-- Pricing -->
  <PricingCards cards={pricingFuite} />

  <!-- Availability CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark-blue mb-2">Vérifiez la disponibilité dans votre zone</h2>
      <p class="text-gray-500 mb-8">Entrez votre code postal pour savoir si nous intervenons chez vous.</p>
      <AvailabilityCTA />
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Fuite d'eau</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        Une fuite d'eau ?<br />Chaque minute compte.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Ne laissez pas une fuite causer des dégâts coûteux. Nos plombiers interviennent en urgence avec l'équipement qu'il faut pour trouver et stopper la fuite.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <CTAButton
          text={`Appel Gratuit : ${siteConfig.phone}`}
          subtext="Détection précise — Réparation garantie — Devis gratuit"
          variant="accent"
          size="lg"
        />
        <button data-open-callback type="button" class="inline-flex flex-col items-center justify-center rounded-2xl font-heading font-bold transition-all duration-300 hover:-translate-y-1 bg-white/10 hover:bg-white/20 text-white shadow-lg px-7 py-5 text-lg cursor-pointer border border-white/20">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Être rappelé
          </span>
          <span class="text-[11px] font-normal opacity-70 mt-0.5">Gratuit — Sans engagement</span>
        </button>
      </div>
      <div class="mt-8 flex justify-center">
        <LiveBadge />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection items={faqItems} title="Questions fréquentes — Recherche de fuite" />

  <!-- SEO Text -->
  <SEOTextBlock title="Expert en recherche et réparation de fuite à Namur">
    <p>
      <strong>ITR Services</strong> est votre spécialiste en <strong>recherche et réparation de fuite à Namur</strong>
      et ses alentours. Grâce à notre équipement de détection —
      <strong>caméra thermique</strong>, <strong>détecteur d'humidité</strong> et <strong>caméra d'inspection vidéo</strong> —
      nous localisons les fuites cachées sans travaux destructifs.
    </p>
    <p>
      Une fuite non traitée, c'est le risque d'infiltrations, de moisissures, de dommages
      structurels et de factures d'eau qui explosent. Notre approche : <strong>détecter sans casser</strong>
      grâce à l'imagerie thermique, puis <strong>réparer sur place dans la foulée</strong>.
    </p>
    <p>
      Disponibles <strong>24h/24 et 7j/7</strong>, nous intervenons dans les heures qui suivent votre appel pour toute urgence
      de fuite à Namur et ses alentours. Nos réparations sont <strong>garanties</strong> et réalisées avec des
      matériaux éprouvés. Nos tarifs commencent dès 249€ pour une recherche et réparation complète.
    </p>
    <p>
      Nos plombiers maîtrisent plusieurs techniques de détection complémentaires : la <strong>détection acoustique
      par ultrasons</strong> pour les fuites sur canalisations sous pression, la <strong>détection par colorant</strong>
      pour les infiltrations en toiture, et l'<strong>inspection par caméra endoscopique</strong> pour visualiser
      l'intérieur des canalisations. Cette polyvalence nous permet de trouver la source exacte du problème,
      quelle que soit sa nature.
    </p>
    <p>
      Nous intervenons sur tous types de fuites : <strong>canalisations encastrées</strong>, tuyaux en cuivre,
      raccords PER, collecteurs, vannes d'arrêt et robinetterie. Que la fuite soit visible ou cachée derrière
      un mur, sous une dalle ou dans un vide sanitaire, nos plombiers disposent de l'équipement nécessaire
      pour la localiser et la réparer. Zone d'intervention : {zone.areasShort}.
    </p>
    <p>
      En cas de <strong>dégât des eaux</strong>, nous fournissons un rapport d'intervention détaillé avec
      photos avant/après, utile pour vos démarches auprès de votre compagnie d'assurance. Nos plombiers
      peuvent également effectuer une <strong>coupure d'eau d'urgence</strong> et sécuriser votre installation
      en attendant la réparation définitive.
    </p>
    <p>
      La qualité de nos réparations est notre priorité. Nous utilisons exclusivement des matériaux de marques
      reconnues et chaque intervention est couverte par notre <strong>garantie main-d'œuvre</strong>. Si le
      problème réapparaît, nous revenons gratuitement.
    </p>
    <p>
      Contactez <strong>ITR Services</strong> au <strong>{siteConfig.phone}</strong> pour une recherche de fuite
      précise et une réparation qui tient. Devis gratuit et sans engagement.
    </p>
  </SEOTextBlock>

  <CallbackModal />
</BaseLayout>
