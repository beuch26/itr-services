---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import PortfolioGallery from "../components/PortfolioGallery.astro";
import LiveBadge from "../components/LiveBadge.astro";
import AvailabilityCTA from "../components/AvailabilityCTA.astro";
import CallbackModal from "../components/CallbackModal.astro";
import { siteConfig } from "../data/siteConfig";
import { faqDebouchage } from "../data/faq";
import { pricingDebouchage } from "../data/pricing";
---

<BaseLayout
  title="Débouchage Bruxelles | Canalisation, WC, Évier - ITR Services"
  description="Débouchage professionnel de canalisations, WC, éviers et douches à Bruxelles et ses alentours. Dès 149€, intervention 24h/24. Devis gratuit. Appelez le +32 470 96 08 23."
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Débouchage", href: "/debouchage-bruxelles-schaerbeek-anderlecht" },
  ]} />

  <HeroSection
    h1="Débouchage de canalisations à Bruxelles et ses alentours"
    slogan="WC, évier, douche, canalisation — Débouchage garanti dès 129€."
    description="Furet mécanique, hydrocurage, caméra d'inspection — on débloque la situation rapidement. <strong class='text-gray-700'>Résultat garanti</strong>, devis gratuit."
    imagePrompt="Professional plumber unclogging a drain with professional equipment"
    imageAlt="Avant/après débouchage d'un regard par ITR Services"
    imageSrc="/images/avant-apres-debouchage-regard.webp"
  />

  <!-- Social proof: Full reviews -->
  <SocialProofFull />

  <!-- Local Info (zone d'intervention) -->
  <LocalInfo localInfoTitle="Débouchage à Bruxelles – Intervention 24h/24" />

  <!-- Service details -->
  <TextImageCTA
    title="Canalisation bouchée ? On intervient, vous respirez."
    text="Évier qui ne se vide plus, WC bouché, douche qui refoule, odeurs qui remontent… Ce genre de situation, ça ne peut pas attendre. Nos plombiers arrivent avec le matériel qu'il faut — furet mécanique, hydrocurage, caméra d'inspection — et ils ne repartent pas tant que ça ne coule pas comme il faut."
    imagePrompt="Professional drain unclogging equipment in action"
    imageAlt="Avant/après débouchage de WC par ITR Services"
    imageSrc="/images/avant-apres-debouchage-wc.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Intervention rapide - Dès 129€"
    features={[
      "Débouchage WC, évier, douche, baignoire",
      "Furet mécanique et hydrocurage haute pression",
      "Caméra d'inspection pour bouchons complexes",
      "Résultat garanti ou retour gratuit",
    ]}
  />

  <TextImageCTA
    title="Zéro produit chimique, 100% mécanique."
    text="Les produits Destop & co ? Ils soulagent deux jours et abîment vos tuyaux sur le long terme. Nous, on traite le problème à la source avec des techniques mécaniques : le furet pour les bouchons accessibles, l'hydrocurage haute pression pour les obstructions profondes. Graisse, calcaire, racines, objets coincés — tout y passe."
    imagePrompt="Close-up of hydro-jetting equipment cleaning a pipe"
    imageAlt="Avant/après débouchage d'évier par ITR Services"
    imageSrc="/images/avant-apres-debouchage-evier.webp"
    imagePosition="left"
    ctaText="Appeler Joseph"
    ctaSubtext="Sans produit chimique - Sans engagement"
    features={[
      "Furet mécanique pour bouchons courants",
      "Hydrocurage haute pression pour les cas sérieux",
      "Caméra d'inspection pour voir l'intérieur du tuyau",
      "Respectueux de vos canalisations et de l'environnement",
    ]}
  />

  <TextImageCTA
    title="Hydrocurage et caméra d'inspection : on voit ce qu'on fait."
    text="Quand un bouchon résiste ou revient sans cesse, nos plombiers passent à l'étape supérieure. L'hydrocurage haute pression nettoie l'intégralité de la canalisation — graisse, calcaire, racines — et la caméra d'inspection vidéo permet de voir l'état exact du tuyau. Résultat : un diagnostic précis et un débouchage définitif, sans surprise."
    imagePrompt="Camera inspection inside a drain pipe"
    imageAlt="Inspection caméra de canalisation par ITR Services"
    imageSrc="/images/portfolio/camera-roscope-rothenberger.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Diagnostic caméra inclus — Dès 149€"
    features={[
      "Hydrocurage haute pression jusqu'à 200 bars",
      "Caméra endoscopique pour diagnostic visuel",
      "Rapport d'inspection sur demande",
      "Idéal pour bouchons récurrents et canalisations anciennes",
    ]}
  />

  <!-- Portfolio -->
  <PortfolioGallery />

  <!-- Pricing -->
  <PricingCards cards={pricingDebouchage} />

  <!-- Availability CTA -->
  <AvailabilityCTA />

  <!-- Final CTA -->
  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Canalisation bouchée</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        WC bouché ? Évier bloqué ?<br />On débouche dans l'heure.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Débouchage garanti à Bruxelles et ses alentours. On arrive vite, on règle le problème, et on vous laisse tranquille. Dès 129€.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <CTAButton
          text={`Appel Gratuit : ${siteConfig.phone}`}
          subtext="Débouchage garanti — Dès 149€ — Devis gratuit"
          variant="accent"
          size="lg"
        />
        <button data-open-callback type="button" class="inline-flex flex-col items-center justify-center rounded-2xl font-heading font-bold transition-all duration-300 hover:-translate-y-1 bg-white/10 hover:bg-white/20 text-white shadow-lg px-7 py-5 text-lg cursor-pointer border border-white/20">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Être rappelé
          </span>
          <span class="text-[11px] font-normal opacity-70 mt-0.5">Gratuit — Sans engagement</span>
        </button>
      </div>
      <div class="mt-8 flex justify-center"><LiveBadge /></div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection items={faqDebouchage} title="Questions fréquentes — Débouchage" />

  <!-- SEO Text -->
  <SEOTextBlock title="Débouchage à Bruxelles : garanti, sans produit chimique">
    <p>
      <strong>ITR Services</strong> est votre expert en <strong>débouchage de canalisations à Bruxelles et ses alentours</strong>. Nous intervenons en urgence <strong>24h/24</strong>
      pour déboucher tous types de canalisations : <strong>WC</strong>, <strong>éviers</strong>, <strong>douches</strong>,
      <strong>baignoires</strong> et <strong>canalisations principales</strong>. Nos plombiers se déplacent dans les heures qui suivent votre appel, équipés pour traiter n'importe quel type de bouchon.
    </p>
    <p>
      Nos plombiers utilisent des méthodes mécaniques éprouvées : <strong>furet mécanique</strong> pour les
      bouchons courants et <strong>hydrocurage haute pression</strong> pour les obstructions tenaces.
      Pour les cas complexes, notre <strong>caméra d'inspection vidéo</strong> permet de voir exactement
      ce qui bloque et d'adapter la méthode en conséquence.
    </p>
    <p>
      Les bouchons de canalisations ont des causes variées : accumulation de <strong>graisse et de savon</strong> dans les éviers,
      <strong>cheveux et résidus</strong> dans les douches, <strong>papier et lingettes</strong> dans les WC, ou encore
      <strong>racines d'arbres</strong> qui s'infiltrent dans les canalisations extérieures. Chaque situation nécessite une approche adaptée,
      et nos plombiers savent exactement quelle technique utiliser pour un résultat durable.
    </p>
    <p>
      Pas de <strong>produits chimiques</strong> chez nous : ils abîment vos canalisations et ne résolvent
      rien en profondeur. Nos techniques mécaniques sont plus efficaces et préservent vos installations.
      Chaque débouchage est <strong>garanti</strong> : si le bouchon revient, on revient aussi — gratuitement.
    </p>
    <p>
      En cas d'<strong>urgence débouchage</strong>, nos plombiers interviennent rapidement à Bruxelles et ses alentours,
      y compris les soirs, week-ends et jours fériés. Une canalisation bouchée peut vite dégénérer en dégât des eaux —
      n'attendez pas que la situation empire. Un simple appel suffit pour déclencher une intervention dans les heures qui suivent votre appel.
    </p>
    <p>
      Nos interventions incluent systématiquement un <strong>diagnostic avant/après</strong>. Grâce à la caméra d'inspection,
      nous vous montrons l'état de vos canalisations avant et après le débouchage. Vous voyez le résultat de vos propres yeux,
      et nous pouvons vous conseiller sur d'éventuels travaux préventifs pour éviter les récidives.
    </p>
    <p>
      Pour <strong>prévenir les bouchons</strong>, quelques gestes simples : ne jetez jamais de graisse dans l'évier,
      utilisez des grilles de protection sur les bondes de douche, et évitez de jeter des lingettes dans les WC — même celles dites « biodégradables ».
      Un entretien préventif par hydrocurage une fois par an peut également prolonger la durée de vie de vos canalisations.
    </p>
    <p>
      <strong>À partir de 149€</strong>, devis gratuit sur place. Appelez <strong>ITR Services</strong>
      au <strong>{siteConfig.phone}</strong> pour un débouchage rapide et garanti à Bruxelles et ses alentours.
    </p>
  </SEOTextBlock>

  <CallbackModal />
</BaseLayout>
