---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import { siteConfig } from "../data/siteConfig";
import { faqBoiler } from "../data/faq";
import { pricingBoiler } from "../data/pricing";
import { getZone } from "../data/zones";
import LiveBadge from "../components/LiveBadge.astro";
import AvailabilityCTA from "../components/AvailabilityCTA.astro";
import CallbackModal from "../components/CallbackModal.astro";

const zone = getZone("namur");
---

<BaseLayout
  title="Réparation & Remplacement Boiler Namur et Alentours - ITR Services"
  description={`Réparation et remplacement de boiler à Namur et ses alentours. Diagnostic gratuit, intervention le jour même, garantie constructeur. Appelez le ${siteConfig.phone}.`}
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Boiler (réparation & remplacement)", href: "/remplacement-boiler-namur" },
  ]} />

  <HeroSection
    h1="Réparation & remplacement de boiler à Namur et ses alentours"
    slogan="Boiler en panne ? On le répare ou on le remplace le jour même."
    description="Diagnostic gratuit sur place. Si votre boiler peut être réparé, on le répare. Sinon, on le remplace dans la journée. <strong class='text-gray-700'>Marques fiables, garantie incluse</strong>."
    imagePrompt=""
    imageAlt="Avant/après remplacement de boiler par ITR Services"
    imageSrc="/images/avant-apres-boiler-thermor.webp"
  />

  <!-- Social proof: Full reviews -->
  <SocialProofFull />

  <!-- Local Info (zone d'intervention) -->
  <LocalInfo
    mapCenter={zone.mapCenter}
    mapZoom={zone.mapZoom}
    mapRadius={zone.mapRadius}
    mapPopupText={zone.mapPopupText}
    areasDetailed={zone.areasDetailed}
    localInfoTitle={`Remplacement de boiler à ${zone.citiesInline} – Intervention rapide`}
    localInfoText={zone.localInfoText}
  />

  <!-- Service details -->
  <TextImageCTA
    title="Boiler en panne ? On diagnostique et on agit."
    text="Plus d'eau chaude, un boiler qui fuit ou qui fait des bruits étranges — pas besoin d'attendre une semaine. Nos plombiers diagnostiquent le problème sur place : si une réparation suffit, on la fait. Si le remplacement s'impose, on l'effectue le jour même. On repart, vous avez de l'eau chaude."
    imagePrompt=""
    imageAlt="Avant/après remplacement de boiler sous évier par ITR Services"
    imageSrc="/images/avant-apres-boiler-evier.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Remplacement le jour même - Devis gratuit"
    features={[
      "Diagnostic gratuit de votre boiler actuel",
      "Conseil personnalisé sur le modèle adapté",
      "Dépose de l'ancien + installation du nouveau",
      "Mise en service et vérification complète",
    ]}
  />

  <TextImageCTA
    title="Atlantic, Ariston, Bosch — on installe les marques qui tiennent."
    text="On ne pose pas n'importe quoi. Nous travaillons avec des marques reconnues pour leur fiabilité — Atlantic, Ariston et Bosch en tête. Notre équipe vous oriente vers le modèle adapté à la taille de votre foyer, vos habitudes de consommation et votre budget. Pas de vente forcée, juste du bon conseil."
    imagePrompt=""
    imageAlt="Avant/après remplacement de boiler Fisch vers Ariston par ITR Services"
    imageSrc="/images/avant-apres-boiler-fisch.webp"
    imagePosition="left"
    ctaText="Appeler Joseph"
    ctaSubtext="Conseil personnalisé - Sans engagement"
    features={[
      "Marques éprouvées : Atlantic, Ariston, Bosch",
      "Garantie constructeur de 2 à 5 ans",
      "Garantie main-d'œuvre ITR Services",
      "Accompagnement et service après-vente",
    ]}
  />

  <TextImageCTA
    title="Quel boiler choisir ? On vous guide sans jargon."
    text="50 litres, 100 litres, 150 litres ? Électrique ou thermodynamique ? Le choix d'un boiler dépend de la taille de votre foyer, de vos habitudes de consommation et de votre installation existante. Nos plombiers prennent le temps de vous expliquer les options et de vous recommander le modèle le plus adapté — sans chercher à vous vendre le plus cher."
    imagePrompt=""
    imageAlt="Chantier de remplacement de canalisation par ITR Services"
    imageSrc="/images/portfolio/chantier-canalisation.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Conseil gratuit - Dès 249€"
    features={[
      "Analyse de vos besoins en eau chaude",
      "Recommandation du volume et du type adaptés",
      "Comparatif des marques et modèles disponibles",
      "Estimation du coût énergétique annuel",
    ]}
  />

  <!-- Pricing -->
  <PricingCards cards={pricingBoiler} />

  <!-- Availability CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark-blue mb-2">Vérifiez la disponibilité dans votre zone</h2>
      <p class="text-gray-500 mb-8">Entrez votre code postal pour savoir si nous intervenons chez vous.</p>
      <AvailabilityCTA />
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Boiler en panne</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        Plus d'eau chaude ?<br />On s'en occupe aujourd'hui.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Réparation ou remplacement de boiler le jour même à Namur et ses alentours. Marques solides, garantie constructeur, tarif annoncé avant intervention.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <CTAButton
          text={`Appel Gratuit : ${siteConfig.phone}`}
          subtext="Remplacement le jour même — Devis gratuit — Garantie incluse"
          variant="accent"
          size="lg"
        />
        <button data-open-callback type="button" class="inline-flex flex-col items-center justify-center rounded-2xl font-heading font-bold transition-all duration-300 hover:-translate-y-1 bg-white/10 hover:bg-white/20 text-white shadow-lg px-7 py-5 text-lg cursor-pointer border border-white/20">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Être rappelé
          </span>
          <span class="text-[11px] font-normal opacity-70 mt-0.5">Gratuit — Sans engagement</span>
        </button>
      </div>
      <div class="mt-8 flex justify-center">
        <LiveBadge />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection items={faqBoiler} title="Questions fréquentes — Remplacement boiler" />

  <!-- SEO Text -->
  <SEOTextBlock title="Remplacement de boiler à Namur : le jour même, garanti">
    <p>
      <strong>ITR Services</strong> assure le <strong>remplacement de boiler à Namur</strong>
      et ses alentours. Que votre boiler soit en panne, qu'il fuie ou
      qu'il ne chauffe plus, nos plombiers interviennent pour diagnostiquer le problème
      et, si nécessaire, procéder à son <strong>remplacement le jour même</strong>.
    </p>
    <p>
      Nous installons des <strong>boilers</strong> de marques reconnues — Atlantic, Ariston
      et Bosch — choisies pour leur fiabilité et leur rendement énergétique. Chaque installation comprend
      la <strong>dépose de l'ancien appareil</strong>, la fourniture et la pose du nouveau boiler,
      ainsi que la <strong>mise en service complète</strong>.
    </p>
    <p>
      Nos tarifs commencent dès 249€ pour une réparation et à <strong>899€ tout compris</strong> pour un remplacement standard, avec
      <strong>garantie constructeur</strong> et garantie main-d'œuvre incluses. On vous conseille le
      modèle adapté à votre foyer, sans pousser à la vente.
    </p>
    <p>
      Comment choisir le bon volume ? Pour un foyer d'une à deux personnes, un boiler de <strong>50 à 80 litres</strong>
      suffit généralement. Pour une famille de trois à quatre personnes, comptez <strong>100 à 150 litres</strong>.
      Au-delà, un modèle de <strong>200 litres ou plus</strong> sera recommandé. Nos plombiers prennent en compte
      vos habitudes de consommation pour vous orienter vers le volume idéal.
    </p>
    <p>
      Un boiler qui vieillit consomme davantage d'énergie et présente un risque accru de fuite. Si votre appareil
      a plus de <strong>10 ans</strong>, un remplacement peut s'avérer plus économique qu'une énième réparation.
      Les modèles récents offrent une meilleure isolation et un rendement supérieur, ce qui se traduit par
      des <strong>économies sur votre facture d'énergie</strong>.
    </p>
    <p>
      Nous intervenons dans les heures qui suivent votre appel sur l'ensemble de la zone de Namur :
      {zone.areasShort}. Que ce soit pour une <strong>panne totale</strong>, un boiler qui fuit,
      un groupe de sécurité défaillant ou un thermostat capricieux, nos plombiers arrivent équipés
      pour diagnostiquer et résoudre le problème.
    </p>
    <p>
      Chaque installation est réalisée dans les <strong>règles de l'art</strong> : raccordement hydraulique,
      raccordement électrique conforme, réglage du thermostat et vérification de l'ensemble du circuit.
      Nous récupérons et recyclons votre ancien boiler dans le respect des normes environnementales.
    </p>
    <p>
      Appelez <strong>ITR Services</strong> au <strong>{siteConfig.phone}</strong> pour un devis gratuit
      et un remplacement de boiler sans attendre.
    </p>
  </SEOTextBlock>

  <CallbackModal />
</BaseLayout>
