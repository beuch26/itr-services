---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import { siteConfig } from "../data/siteConfig";
import { faqBoiler } from "../data/faq";
---

<BaseLayout
  title="Remplacement Boiler Bruxelles, Schaerbeek, Anderlecht | Installation - ITR Services"
  description="Remplacement et installation de boiler à Bruxelles, Schaerbeek et Anderlecht. Dès 899€, intervention le jour même, garantie constructeur. Appelez le +32 470 96 08 23."
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Remplacement boiler", href: "/remplacement-boiler-bruxelles-schaerbeek-anderlecht" },
  ]} />

  <HeroSection
    h1="Remplacement de boiler à Bruxelles, Schaerbeek et Anderlecht"
    slogan="Plus d'eau chaude ? On remplace votre boiler le jour même."
    imagePrompt="Professional plumber installing a new water heater boiler"
    imageAlt="Avant/après rénovation salle de bain avec boiler par ITR Services"
    imageSrc="/images/portfolio/renovation-sdb-douche-moderne.jpg"
  />

  <!-- Mini social proof -->
  <section class="py-6 md:py-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 bg-accent-light rounded-2xl p-6 md:p-8">
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <SocialProofMini />
          <span class="hidden sm:block w-px h-8 bg-gray-200"></span>
          <p class="text-gray-600 text-sm text-center sm:text-left">
            <strong class="text-dark-blue">Remplacement boiler dès 899€</strong> — Fourniture + installation + garantie
          </p>
        </div>
        <CTAButton
          text="Appeler maintenant"
          subtext="Devis gratuit"
          size="sm"
        />
      </div>
    </div>
  </section>

  <!-- Service details -->
  <TextImageCTA
    title="Boiler en panne ? On le remplace aujourd'hui."
    text="Plus d'eau chaude, un boiler qui fuit ou qui fait des bruits étranges — pas besoin d'attendre une semaine pour retrouver votre confort. Nos plombiers diagnostiquent le problème sur place et, si le remplacement s'impose, ils l'effectuent le jour même. On repart, vous avez de l'eau chaude."
    imagePrompt="Modern water heater installed in a clean bathroom"
    imageAlt="Chantier de remplacement de boiler par ITR Services"
    imageSrc="/images/portfolio/reparation-tuyau-encastre.jpg"
    imagePosition="right"
    ctaText="Appelez maintenant"
    ctaSubtext="Remplacement le jour même - Devis gratuit"
    features={[
      "Diagnostic gratuit de votre boiler actuel",
      "Conseil personnalisé sur le modèle adapté",
      "Dépose de l'ancien + installation du nouveau",
      "Mise en service et vérification complète",
    ]}
  />

  <TextImageCTA
    title="Atlantic, Ariston, Bosch — on installe les marques qui tiennent."
    text="On ne pose pas n'importe quoi. Nous travaillons avec des marques reconnues pour leur fiabilité — Atlantic, Ariston et Bosch en tête. Notre équipe vous oriente vers le modèle adapté à la taille de votre foyer, vos habitudes de consommation et votre budget. Pas de vente forcée, juste du bon conseil."
    imagePrompt="Various branded water heater boilers"
    imageAlt="Avant/après installation robinetterie de qualité par ITR Services"
    imageSrc="/images/portfolio/reparation-robinetterie.jpg"
    imagePosition="left"
    ctaText="Demandez un devis gratuit"
    ctaSubtext="Conseil personnalisé - Sans engagement"
    features={[
      "Marques éprouvées : Atlantic, Ariston, Bosch",
      "Garantie constructeur de 2 à 5 ans",
      "Garantie main-d'œuvre ITR Services",
      "Accompagnement et service après-vente",
    ]}
  />

  <!-- Social proof -->
  <SocialProofFull />

  <!-- Pricing -->
  <PricingCards cards={[
    {
      title: "Réparation boiler",
      price: "89",
      unit: "€",
      description: "Diagnostic et réparation de votre boiler",
      features: [
        "Diagnostic complet sur place",
        "Réparation si l'appareil le permet",
        "Pièces incluses dans le tarif",
        "Garantie sur la réparation",
      ],
    },
    {
      title: "Remplacement standard",
      price: "899",
      unit: "€",
      description: "Nouveau boiler fourni, posé et mis en service",
      features: [
        "Dépose de l'ancien boiler",
        "Fourniture appareil neuf",
        "Installation et raccordement",
        "Garantie constructeur incluse",
      ],
      highlighted: true,
    },
    {
      title: "Grande capacité (150L+)",
      price: "1199",
      unit: "€",
      description: "Pour les foyers de 3 personnes et plus",
      features: [
        "Boiler 150 litres ou plus",
        "Marque au choix (Atlantic, Ariston…)",
        "Installation et mise en service",
        "Garantie constructeur 5 ans",
      ],
    },
  ]} />

  <!-- Final CTA -->
  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Boiler en panne</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        Plus d'eau chaude ?<br />On s'en occupe aujourd'hui.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Remplacement de boiler le jour même à Bruxelles, Schaerbeek et Anderlecht. Marques solides, garantie constructeur, tarif annoncé avant intervention.
      </p>
      <CTAButton
        text={`Appel Gratuit : ${siteConfig.phone}`}
        subtext="Remplacement le jour même — Devis gratuit — Garantie incluse"
        variant="accent"
        size="lg"
      />
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection items={faqBoiler} title="Questions fréquentes — Remplacement boiler" />

  <!-- SEO Text -->
  <SEOTextBlock title="Remplacement de boiler à Bruxelles : le jour même, garanti">
    <p>
      <strong>ITR Services</strong> assure le <strong>remplacement de boiler à Bruxelles</strong>,
      <strong>Schaerbeek</strong> et <strong>Anderlecht</strong>. Que votre boiler soit en panne, qu'il fuie ou
      qu'il ne chauffe plus, nos plombiers interviennent pour diagnostiquer le problème
      et, si nécessaire, procéder à son <strong>remplacement le jour même</strong>.
    </p>
    <p>
      Nous installons des <strong>boilers</strong> de marques reconnues — Atlantic, Ariston
      et Bosch — choisies pour leur fiabilité et leur rendement énergétique. Chaque installation comprend
      la <strong>dépose de l'ancien appareil</strong>, la fourniture et la pose du nouveau boiler,
      ainsi que la <strong>mise en service complète</strong>.
    </p>
    <p>
      Nos tarifs commencent à <strong>899€ tout compris</strong> pour un remplacement standard, avec
      <strong>garantie constructeur</strong> et garantie main-d'œuvre incluses. On vous conseille le
      modèle adapté à votre foyer, sans pousser à la vente.
    </p>
    <p>
      Appelez <strong>ITR Services</strong> au <strong>{siteConfig.phone}</strong> pour un devis gratuit
      et un remplacement de boiler sans attendre.
    </p>
  </SEOTextBlock>

  <LocalInfo />
</BaseLayout>
