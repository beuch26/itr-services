---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import AuthorityBrands from "../components/AuthorityBrands.astro";
import PortfolioGallery from "../components/PortfolioGallery.astro";
import { siteConfig } from "../data/siteConfig";
import { faqDepannage } from "../data/faq";
import { pricingHomepage } from "../data/pricing";
---

<BaseLayout
  title="Plombier Dépannage Bruxelles, Schaerbeek, Anderlecht | Urgence 24h/24 - ITR Services"
  description="Plombier dépannage urgent à Bruxelles, Schaerbeek et Anderlecht. Intervention en 30-60 min, 24h/24 et 7j/7. Devis gratuit, tarifs transparents. Appelez le +32 470 96 08 23."
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Plomberie dépannage", href: "/plombier-bruxelles-schaerbeek-anderlecht" },
  ]} />

  <HeroSection
    h1="Plombier dépannage à Bruxelles, Schaerbeek et Anderlecht — Urgence 24h/24"
    slogan="Un problème de plomberie ? On est chez vous dans l'heure."
    imagePrompt="Professional plumber fixing an emergency pipe leak under a kitchen sink, dramatic lighting, urgent atmosphere"
    imageAlt="Plombier ITR Services en intervention d'urgence à Bruxelles"
    imageSrc="/images/portfolio/chantier-reparation-tuyau.jpg"
  />

  <!-- Mini social proof -->
  <section class="py-6 md:py-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 bg-accent-light rounded-2xl p-6 md:p-8">
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <SocialProofMini />
          <span class="hidden sm:block w-px h-8 bg-gray-200"></span>
          <p class="text-gray-600 text-sm text-center sm:text-left">
            <strong class="text-dark-blue">Intervention rapide</strong> — Sur place en 30 à 60 minutes*
          </p>
        </div>
        <CTAButton
          text="Appeler maintenant"
          subtext="Urgence 24h/24"
          size="sm"
        />
      </div>
    </div>
  </section>

  <!-- Service details -->
  <TextImageCTA
    title="Fuite, robinet cassé, canalisation percée — on gère."
    text="L'eau qui coule là où elle ne devrait pas, c'est le genre de problème qui ne peut pas attendre demain. Chez ITR Services, on le sait : quand ça fuit, chaque minute compte. C'est pourquoi nos plombiers sont sur place en 30 à 60 minutes* à Bruxelles, Schaerbeek et Anderlecht — de jour comme de nuit."
    imagePrompt="Close-up of professional plumber repairing copper pipe"
    imageAlt="Réparation de tuyau par un plombier professionnel ITR Services"
    imageSrc="/images/portfolio/chantier-reparation-tuyau.jpg"
    imagePosition="right"
    ctaText="Appelez maintenant"
    ctaSubtext="Intervention en 30 min* - Devis gratuit"
    features={[
      "Disponible 24h/24, 7j/7, jours fériés inclus",
      "Sur place en 30 à 60 minutes*",
      "Diagnostic gratuit avant toute intervention",
      "Aucun frais de déplacement caché",
    ]}
  />

  <AuthorityBrands />

  <TextImageCTA
    title="Du joint qui goutte au tuyau qui lâche, on s'occupe de tout."
    text="Pas besoin d'appeler trois artisans différents. Nos plombiers sont formés pour intervenir sur tous les problèmes de plomberie, en résidentiel comme en commercial. Un seul appel, un seul interlocuteur, et votre problème est réglé."
    imagePrompt="Professional plumbing tools and equipment"
    imageAlt="Chantier de canalisation réalisé par ITR Services"
    imageSrc="/images/portfolio/chantier-canalisation.jpg"
    imagePosition="left"
    ctaText="Demandez un devis gratuit"
    ctaSubtext="Réponse immédiate - Sans engagement"
    features={[
      "Fuites d'eau et canalisations percées",
      "Robinets, mitigeurs et chasses d'eau",
      "Problèmes de pression et de débit",
      "Joints, siphons, vannes et raccords",
    ]}
  />

  <!-- Social proof -->
  <SocialProofFull />

  <!-- Portfolio -->
  <PortfolioGallery />

  <!-- Pricing -->
  <PricingCards cards={pricingHomepage} />

  <!-- Final CTA -->
  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Urgence plomberie</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        Besoin d'un plombier en urgence ?<br />Appelez, on arrive.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Nos plombiers sont disponibles 24h/24 pour intervenir à Bruxelles, Schaerbeek et Anderlecht. Devis gratuit, pas de surprise sur la facture.
      </p>
      <CTAButton
        text={`Appel Gratuit : ${siteConfig.phone}`}
        subtext="Intervention en 30 min* — Devis gratuit — Sans engagement"
        variant="accent"
        size="lg"
      />
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection items={faqDepannage} title="Questions fréquentes — Dépannage plomberie" />

  <!-- SEO Text -->
  <SEOTextBlock title="Votre plombier dépannage de confiance à Bruxelles">
    <p>
      <strong>ITR Services</strong> est votre plombier de référence pour le <strong>dépannage plomberie à Bruxelles</strong>,
      <strong>Schaerbeek</strong> et <strong>Anderlecht</strong>. Disponibles <strong>24h/24 et 7j/7</strong>, nos plombiers
      qualifiés interviennent en urgence pour résoudre tous vos problèmes : fuites d'eau, canalisations percées,
      robinets défaillants, chasses d'eau en panne et tout autre souci de plomberie.
    </p>
    <p>
      Notre force : être <strong>sur place en 30 à 60 minutes*</strong> avec un diagnostic gratuit.
      On vous présente un devis clair avant toute réparation. Pas de frais de déplacement cachés,
      pas de surfacturation. Nos tarifs sont parmi les plus compétitifs de la région bruxelloise.
    </p>
    <p>
      Nos plombiers travaillent avec du matériel adapté à chaque situation et utilisent des pièces
      de marques reconnues (Grohe, Geberit, Vaillant). Chaque intervention est
      <strong>garantie</strong> pour votre tranquillité d'esprit.
    </p>
    <p>
      Contactez <strong>ITR Services</strong> dès maintenant au <strong>{siteConfig.phone}</strong> pour un
      dépannage plomberie à Bruxelles, Schaerbeek ou Anderlecht.
    </p>
  </SEOTextBlock>

  <LocalInfo />
</BaseLayout>
