---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import AuthorityBrands from "../components/AuthorityBrands.astro";
import PortfolioGallery from "../components/PortfolioGallery.astro";
import LiveBadge from "../components/LiveBadge.astro";
import AvailabilityCTA from "../components/AvailabilityCTA.astro";
import CallbackModal from "../components/CallbackModal.astro";
import { siteConfig } from "../data/siteConfig";
import { faqDepannage } from "../data/faq";
import { pricingHomepage } from "../data/pricing";
---

<BaseLayout
  title="Plombier Dépannage Bruxelles, Schaerbeek, Anderlecht | Dépannage 24h/24 - ITR Services"
  description="Plombier dépannage urgent à Bruxelles, Schaerbeek et Anderlecht dès 149€. Intervention rapide 24h/24, 7j/7. Devis gratuit, tarifs transparents. Appelez le +32 470 96 08 23."
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Plomberie dépannage", href: "/plombier-bruxelles-schaerbeek-anderlecht" },
  ]} />

  <HeroSection
    h1="Plombier dépannage à Bruxelles et ses alentours — 24h/24"
    slogan="Un problème de plomberie ? On est chez vous dans l'heure."
    description="Fuite, panne, canalisation bouchée — nos plombiers interviennent en urgence avec un devis clair avant toute réparation. Disponible <strong class='text-gray-700'>24h/24, 7j/7</strong>."
    imagePrompt=""
    imageAlt="Joseph, plombier dépannage ITR Services à Bruxelles"
    imageSrc="/images/plombier-itr-services.webp"
  />

  <!-- Social proof: Full reviews -->
  <SocialProofFull />

  <!-- Local Info (zone d'intervention) -->
  <LocalInfo />

  <!-- Service details -->
  <TextImageCTA
    title="Fuite, robinet cassé, canalisation percée — on gère."
    text="L'eau qui coule là où elle ne devrait pas, c'est le genre de problème qui ne peut pas attendre demain. Chez ITR Services, on le sait : quand ça fuit, chaque minute compte. C'est pourquoi nos plombiers sont sur place dans les heures qui suivent votre appel à Bruxelles et ses alentours — de jour comme de nuit."
    imagePrompt="Close-up of professional plumber repairing copper pipe"
    imageAlt="Avant/après réparation de tuyau encastré par ITR Services"
    imageSrc="/images/portfolio/reparation-tuyau-encastre.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Intervention rapide - Devis gratuit"
    features={[
      "Disponible 24h/24, 7j/7, jours fériés inclus",
      "Intervention dans les heures qui suivent l'appel",
      "Diagnostic gratuit avant toute intervention",
      "Aucun frais de déplacement caché",
    ]}
  />

  <AuthorityBrands />

  <TextImageCTA
    title="Du joint qui goutte au tuyau qui lâche, on s'occupe de tout."
    text="Pas besoin d'appeler trois artisans différents. Nos plombiers sont formés pour intervenir sur tous les problèmes de plomberie, en résidentiel comme en commercial. Un seul appel, un seul interlocuteur, et votre problème est réglé."
    imagePrompt="Professional plumbing tools and equipment"
    imageAlt="Avant/après réparation de canalisation en cave par ITR Services"
    imageSrc="/images/portfolio/reparation-canalisation-cave.webp"
    imagePosition="left"
    ctaText="Appeler Joseph"
    ctaSubtext="Réponse immédiate - Sans engagement"
    features={[
      "Fuites d'eau et canalisations percées",
      "Robinets, mitigeurs et chasses d'eau",
      "Problèmes de pression et de débit",
      "Joints, siphons, vannes et raccords",
    ]}
  />

  <TextImageCTA
    title="Urgence plomberie la nuit ou le week-end ? On est là."
    text="Un dégât des eaux à 2h du matin ou un dimanche après-midi ? Nos plombiers sont disponibles 24h/24, 7j/7 — nuits, week-ends et jours fériés inclus. Chez ITR Services, pas de mauvaises surprises : nos tarifs sont transparents même en intervention d'urgence. Vous connaissez le prix avant qu'on commence, et il n'y a aucun supplément caché."
    imagePrompt="Thermal camera pipe detection"
    imageAlt="Détection de fuite par caméra thermique par ITR Services"
    imageSrc="/images/portfolio/detection-camera-thermique.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Disponible maintenant - Devis gratuit"
    features={[
      "Service d'urgence disponible nuit et week-end",
      "Tarifs transparents, sans supplément surprise",
      "Intervention dans l'heure en zone Bruxelles",
      "Matériel professionnel embarqué dans nos véhicules",
    ]}
  />

  <!-- Portfolio -->
  <PortfolioGallery />

  <!-- Pricing -->
  <PricingCards cards={pricingHomepage} />

  <!-- Availability CTA -->
  <AvailabilityCTA />

  <!-- Final CTA -->
  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Dépannage plomberie</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        Besoin d'un plombier en dépannage ?<br />Appelez, on arrive.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Nos plombiers sont disponibles 24h/24 pour intervenir à Bruxelles et ses alentours. Devis gratuit, pas de surprise sur la facture.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <CTAButton
          text={`Appel Gratuit : ${siteConfig.phone}`}
          subtext="Intervention rapide — Devis gratuit — Sans engagement"
          variant="accent"
          size="lg"
        />
        <button data-open-callback type="button" class="inline-flex flex-col items-center justify-center rounded-2xl font-heading font-bold transition-all duration-300 hover:-translate-y-1 bg-white/10 hover:bg-white/20 text-white shadow-lg px-7 py-5 text-lg cursor-pointer border border-white/20">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Être rappelé
          </span>
          <span class="text-[11px] font-normal opacity-70 mt-0.5">Gratuit — Sans engagement</span>
        </button>
      </div>
      <div class="mt-8 flex justify-center">
        <LiveBadge />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection items={faqDepannage} title="Questions fréquentes — Dépannage plomberie" />

  <!-- SEO Text -->
  <SEOTextBlock title="Votre plombier dépannage de confiance à Bruxelles">
    <p>
      <strong>ITR Services</strong> est votre plombier de référence pour le <strong>dépannage plomberie à Bruxelles
      et ses alentours</strong>. Disponibles <strong>24h/24 et 7j/7</strong>, nos plombiers
      qualifiés interviennent en urgence pour résoudre tous vos problèmes : fuites d'eau, canalisations percées,
      robinets défaillants, chasses d'eau en panne et tout autre souci de plomberie. Nos interventions démarrent
      <strong>dès 149€</strong>, avec un devis gratuit et sans engagement.
    </p>
    <p>
      Notre force : être <strong>sur place dans les heures qui suivent votre appel</strong> avec un diagnostic gratuit.
      On vous présente un devis clair avant toute réparation. Pas de frais de déplacement cachés,
      pas de surfacturation. Nos tarifs sont parmi les plus compétitifs de la région bruxelloise.
    </p>
    <p>
      <strong>Types d'interventions que nous réalisons :</strong> réparation de fuites d'eau (apparentes ou encastrées),
      remplacement de robinets et mitigeurs, débouchage de canalisations et siphons, réparation et remplacement
      de chasses d'eau, remise en état de colonnes montantes, réparation de canalisations en cuivre ou PVC,
      recherche de fuite par caméra thermique, et remplacement de vannes d'arrêt. Quel que soit le type de panne,
      nos plombiers ont l'expérience et le matériel pour intervenir efficacement.
    </p>
    <p>
      <strong>Pourquoi choisir ITR Services plutôt qu'un autre plombier ?</strong> Contrairement à de nombreux
      dépanneurs, nous misons sur la transparence totale. Chaque intervention commence par un diagnostic gratuit,
      suivi d'un devis détaillé que vous êtes libre d'accepter ou de refuser. Nos clients apprécient notre
      ponctualité, notre propreté sur chantier et notre communication claire tout au long de l'intervention.
      Avec plus de 150 avis positifs, notre réputation parle d'elle-même.
    </p>
    <p>
      <strong>Zone d'intervention :</strong> nous couvrons l'ensemble de <strong>Bruxelles et ses alentours</strong>,
      y compris Schaerbeek, Anderlecht, Ixelles, Saint-Gilles, Uccle, Forest, Molenbeek, Etterbeek, Woluwe,
      Auderghem, Jette, Koekelberg, Evere, et les communes avoisinantes. Où que vous soyez dans la région
      bruxelloise, un plombier ITR Services peut être chez vous rapidement.
    </p>
    <p>
      Nos plombiers travaillent avec du <strong>matériel professionnel de dernière génération</strong> : caméras
      d'inspection, détecteurs thermiques, pompes de débouchage haute pression et outillage spécialisé.
      Nous utilisons exclusivement des pièces de marques reconnues (Grohe, Geberit, Vaillant) pour garantir
      la durabilité de chaque réparation. Notre équipe est formée en continu aux nouvelles techniques et
      aux normes en vigueur en Belgique.
    </p>
    <p>
      <strong>Satisfaction client et garanties :</strong> chaque intervention est <strong>garantie</strong> pour
      votre tranquillité d'esprit. Si un problème survient après notre passage, nous revenons gratuitement
      pour le corriger. Notre objectif est simple : que vous n'ayez plus jamais à chercher un autre plombier.
      La qualité de notre travail et notre service après-intervention font d'ITR Services le choix de confiance
      pour des milliers de Bruxellois.
    </p>
    <p>
      Contactez <strong>ITR Services</strong> dès maintenant au <strong>{siteConfig.phone}</strong> pour un
      dépannage plomberie dès 149€ à Bruxelles et ses alentours. Intervention rapide, devis gratuit,
      résultat garanti.
    </p>
  </SEOTextBlock>

  <CallbackModal />
</BaseLayout>
