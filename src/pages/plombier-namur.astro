---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import SocialProofMini from "../components/SocialProofMini.astro";
import TextImageCTA from "../components/TextImageCTA.astro";
import SocialProofFull from "../components/SocialProofFull.astro";
import PricingCards from "../components/PricingCards.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOTextBlock from "../components/SEOTextBlock.astro";
import LocalInfo from "../components/LocalInfo.astro";
import AuthorityBrands from "../components/AuthorityBrands.astro";
import PortfolioGallery from "../components/PortfolioGallery.astro";
import { siteConfig } from "../data/siteConfig";
import { getFaqDepannage } from "../data/faq";
import { pricingHomepage } from "../data/pricing";
import { getZone } from "../data/zones";
import LiveBadge from "../components/LiveBadge.astro";
import AvailabilityCTA from "../components/AvailabilityCTA.astro";
import CallbackModal from "../components/CallbackModal.astro";

const zone = getZone("namur");
const faqItems = getFaqDepannage(zone.citiesInline);
---

<BaseLayout
  title="Plombier Dépannage Namur et Alentours | Dépannage 24h/24 - ITR Services"
  description={`Plombier dépannage urgent à Namur et ses alentours. Intervention rapide, 24h/24 et 7j/7. Devis gratuit, tarifs transparents. Appelez le ${siteConfig.phone}.`}
>
  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Plomberie dépannage", href: "/plombier-namur" },
  ]} />

  <HeroSection
    h1="Plombier dépannage à Namur et ses alentours — 24h/24"
    slogan="Un problème de plomberie ? On est chez vous dans l'heure."
    description={`Fuite, panne, canalisation bouchée — nos plombiers interviennent en urgence avec un devis clair avant toute réparation. Disponible <strong class='text-gray-700'>24h/24, 7j/7</strong>.`}
    imagePrompt=""
    imageAlt="Joseph, plombier dépannage ITR Services à Namur"
    imageSrc="/images/plombier-itr-services.webp"
  />

  <SocialProofFull />

  <LocalInfo
    mapCenter={zone.mapCenter}
    mapZoom={zone.mapZoom}
    mapRadius={zone.mapRadius}
    mapPopupText={zone.mapPopupText}
    areasDetailed={zone.areasDetailed}
    localInfoTitle={zone.localInfoTitle}
    localInfoText={zone.localInfoText}
  />

  <TextImageCTA
    title="Fuite, robinet cassé, canalisation percée — on gère."
    text="L'eau qui coule là où elle ne devrait pas, c'est le genre de problème qui ne peut pas attendre demain. Chez ITR Services, on le sait : quand ça fuit, chaque minute compte. C'est pourquoi nos plombiers sont sur place dans les heures qui suivent votre appel à Namur et ses alentours — de jour comme de nuit."
    imagePrompt=""
    imageAlt="Avant/après réparation de tuyau encastré par ITR Services"
    imageSrc="/images/portfolio/reparation-tuyau-encastre.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Intervention rapide - Devis gratuit"
    features={[
      "Disponible 24h/24, 7j/7, jours fériés inclus",
      "Intervention dans les heures qui suivent l'appel",
      "Diagnostic gratuit avant toute intervention",
      "Aucun frais de déplacement caché",
    ]}
  />

  <AuthorityBrands />

  <TextImageCTA
    title="Du joint qui goutte au tuyau qui lâche, on s'occupe de tout."
    text="Pas besoin d'appeler trois artisans différents. Nos plombiers sont formés pour intervenir sur tous les problèmes de plomberie, en résidentiel comme en commercial. Un seul appel, un seul interlocuteur, et votre problème est réglé."
    imagePrompt=""
    imageAlt="Avant/après réparation de canalisation en cave par ITR Services"
    imageSrc="/images/portfolio/reparation-canalisation-cave.webp"
    imagePosition="left"
    ctaText="Appeler Joseph"
    ctaSubtext="Réponse immédiate - Sans engagement"
    features={[
      "Fuites d'eau et canalisations percées",
      "Robinets, mitigeurs et chasses d'eau",
      "Problèmes de pression et de débit",
      "Joints, siphons, vannes et raccords",
    ]}
  />

  <TextImageCTA
    title="Urgence plomberie 24h/24 — même la nuit, même le dimanche."
    text="Un tuyau qui lâche à 2h du matin ou un dégât des eaux un jour férié, ça n'attend pas le lundi. Nos plombiers assurent un service d'urgence 24h/24 et 7j/7 à Namur et ses alentours. Un seul appel suffit : on évalue la situation par téléphone, on vous donne une estimation, et on est chez vous dans les heures qui suivent votre appel."
    imagePrompt=""
    imageAlt="Chantier de réparation de canalisation par ITR Services"
    imageSrc="/images/portfolio/chantier-reparation-tuyau.webp"
    imagePosition="right"
    ctaText="Appeler Joseph"
    ctaSubtext="Disponible 24h/24 - Dès 149€"
    features={[
      "Urgences plomberie jour et nuit, 7j/7",
      "Estimation par téléphone avant déplacement",
      "Intervention dans les heures qui suivent l'appel",
      "Tarifs transparents dès 149€, sans surprise",
    ]}
  />

  <PortfolioGallery />
  <PricingCards cards={pricingHomepage} />

  <!-- Availability CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark-blue mb-2">Vérifiez la disponibilité dans votre zone</h2>
      <p class="text-gray-500 mb-8">Entrez votre code postal pour savoir si nous intervenons chez vous.</p>
      <AvailabilityCTA />
    </div>
  </section>

  <section class="py-14 md:py-20 bg-dark-blue relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="inline-block text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent mb-4">Dépannage plomberie</span>
      <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-5 tracking-tight leading-tight">
        Besoin d'un plombier en dépannage ?<br />Appelez, on arrive.
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Nos plombiers sont disponibles 24h/24 pour intervenir à Namur et ses alentours. Devis gratuit, pas de surprise sur la facture.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <CTAButton
          text={`Appel Gratuit : ${siteConfig.phone}`}
          subtext="Intervention rapide — Devis gratuit — Sans engagement"
          variant="accent"
          size="lg"
        />
        <button data-open-callback type="button" class="inline-flex flex-col items-center justify-center rounded-2xl font-heading font-bold transition-all duration-300 hover:-translate-y-1 bg-white/10 hover:bg-white/20 text-white shadow-lg px-7 py-5 text-lg cursor-pointer border border-white/20">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Être rappelé
          </span>
          <span class="text-[11px] font-normal opacity-70 mt-0.5">Gratuit — Sans engagement</span>
        </button>
      </div>
      <div class="mt-8 flex justify-center">
        <LiveBadge />
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} title="Questions fréquentes — Dépannage plomberie" />

  <SEOTextBlock title="Votre plombier dépannage de confiance à Namur">
    <p>
      <strong>ITR Services</strong> est votre plombier de référence pour le <strong>dépannage plomberie à Namur</strong>
      et ses alentours. Disponibles <strong>24h/24 et 7j/7</strong>, nos plombiers
      qualifiés interviennent en urgence pour résoudre tous vos problèmes : fuites d'eau, canalisations percées,
      robinets défaillants, chasses d'eau en panne et tout autre souci de plomberie.
    </p>
    <p>
      Notre force : être <strong>sur place dans les heures qui suivent votre appel</strong> avec un diagnostic gratuit.
      On vous présente un devis clair avant toute réparation. Pas de frais de déplacement cachés,
      pas de surfacturation. Nos tarifs sont parmi les plus compétitifs de la région namuroise, dès 149€.
    </p>
    <p>
      Nos plombiers travaillent avec du matériel adapté à chaque situation et utilisent des pièces
      de marques reconnues (Grohe, Geberit, Vaillant). Chaque intervention est
      <strong>garantie</strong> pour votre tranquillité d'esprit.
    </p>
    <p>
      Que ce soit pour une <strong>fuite d'eau urgente</strong>, un <strong>robinet qui goutte</strong>,
      une <strong>chasse d'eau défaillante</strong> ou un <strong>problème de pression</strong>, nos plombiers
      disposent de l'outillage et des pièces nécessaires pour régler le problème en une seule visite.
      Nous intervenons dans l'ensemble de la province de Namur : {zone.areasShort}.
    </p>
    <p>
      La transparence tarifaire est au cœur de notre démarche. Avant chaque réparation, nos plombiers vous présentent
      un <strong>devis détaillé</strong> que vous êtes libre d'accepter ou de refuser. Pas de frais cachés, pas de
      majoration de nuit abusive. Vous savez exactement ce que vous allez payer avant que le moindre outil ne sorte
      de la camionnette.
    </p>
    <p>
      En cas de <strong>dégât des eaux</strong>, nos plombiers peuvent également vous accompagner dans les démarches
      auprès de votre assurance : constat, rapport d'intervention, photos avant/après. Un service complet pour vous
      simplifier la vie dans un moment stressant.
    </p>
    <p>
      Notre engagement qualité ne s'arrête pas à la réparation. Chaque intervention est suivie d'une
      <strong>vérification complète</strong> de l'installation pour s'assurer qu'aucun autre problème ne se cache.
      C'est cette rigueur qui nous vaut la confiance de centaines de clients à Namur et ses alentours.
    </p>
    <p>
      Contactez <strong>ITR Services</strong> dès maintenant au <strong>{siteConfig.phone}</strong> pour un
      dépannage plomberie à Namur et ses alentours. Devis gratuit et sans engagement.
    </p>
  </SEOTextBlock>

  <CallbackModal />
</BaseLayout>
